{
  "name": "cms1500-react",
  "version": "1.2.1",
  "description": "Production-ready React library for rendering, filling, and printing CMS-1500 (HCFA) claim forms via PDF with FHIR-compatible input",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "bin": {
    "cms1500-copy-template": "./scripts/copy-template.js"
  },
  "files": [
    "dist",
    "assets",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "cms-1500",
    "cms1500",
    "hcfa",
    "medical-claim",
    "medical-billing",
    "healthcare",
    "ehr",
    "emr",
    "electronic-health-record",
    "health-information",
    "clinical",
    "insurance-claim",
    "claim-form",
    "fhir",
    "hl7",
    "hipaa",
    "react",
    "print",
    "pdf",
    "pdf-lib",
    "medical-form",
    "health-insurance",
    "revenue-cycle",
    "rcm",
    "superbill",
    "clearinghouse"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rajkumar4041/cms1500-react"
  },
  "sideEffects": false
}
